  function loadData() {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (!saved) return;
      const d = JSON.parse(saved);
      // Only restore the transactions array — recompute all aggregates
      // from scratch so stale/buggy stored values never pollute the UI.
      const raw = Array.isArray(d.transactions) ? d.transactions : [];
      // Sort ascending so lent always precedes its repayment when replaying
      transactions = [...raw].sort((a, b) => a.date < b.date ? -1 : a.date > b.date ? 1 : 0);
      balance = 0; youOwe = 0; othersOwe = 0; investments = 0; totalGift = 0;
      borrowedMap = {}; lentMap = {}; giftMap = {};
      transactions.forEach(t => apply(t));
    } catch (e) {
      console.error("Load error:", e);
    }
  }

