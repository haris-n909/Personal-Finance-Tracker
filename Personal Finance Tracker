      const o = document.createElement("option");
      o.value = o.textContent = c;
      if (c === cur) o.selected = true;
      sel.appendChild(o);
    });
  }

  function renderMonthlySummary() {
    const yearSel = ge("monthlyYear");
    const selYear = parseInt(yearSel.value) || new Date().getFullYear();

    // Populate year dropdown from transaction dates
    const years = [...new Set(transactions.map(t => t.date ? t.date.split("-")[0] : null).filter(Boolean))].sort();
    if (years.length === 0) years.push(String(new Date().getFullYear()));
    const curVal = yearSel.value;
    yearSel.innerHTML = "";
    years.forEach(y => {
      const o = document.createElement("option");
      o.value = o.textContent = y;
      if (y === curVal || (!curVal && parseInt(y) === new Date().getFullYear())) o.selected = true;
      yearSel.appendChild(o);
    });
    const activeYear = yearSel.value || years[years.length - 1];

    const container = ge("monthlySummaryContent");
    container.innerHTML = "";

    const MONTHS = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];

    // Build month data for selected year
    for (let m = 0; m < 12; m++) {
      const prefix = activeYear + "-" + String(m + 1).padStart(2, "0");
      const monthTxs = transactions.filter(t => t.date && t.date.startsWith(prefix));
      if (monthTxs.length === 0) continue;

      let totalIncome = 0, totalExpense = 0;
      const incCats = {}, expCats = {};

      monthTxs.forEach(t => {
        if (t.type === "income") {
          totalIncome += t.amount;
          incCats[t.category] = (incCats[t.category] || 0) + t.amount;
        } else {
          totalExpense += t.amount;
          expCats[t.category] = (expCats[t.category] || 0) + t.amount;
        }
      });

      const net = totalIncome - totalExpense;
      const block = document.createElement("div");
      block.className = "month-block";

      const header = document.createElement("div");
      header.className = "month-header";

      const titleSpan = document.createElement("span");
      titleSpan.textContent = MONTHS[m] + " " + activeYear;

      const rightDiv = document.createElement("div");
      rightDiv.className = "mh-right";

      const incSpan = document.createElement("span");
      incSpan.className = "mh-inc";
      incSpan.textContent = "+₹" + totalIncome.toFixed(0);

      const expSpan = document.createElement("span");
      expSpan.className = "mh-exp";
      expSpan.textContent = "-₹" + totalExpense.toFixed(0);

      const netSpan = document.createElement("span");
      netSpan.className = "mh-net " + (net >= 0 ? "pos" : "neg");
      netSpan.textContent = (net >= 0 ? "▲" : "▼") + " ₹" + Math.abs(net).toFixed(0);

      const arrow = document.createElement("span");
      arrow.textContent = "▶";
      arrow.style.cssText = "font-size:12px;color:var(--muted);transition:transform 0.2s;";

      rightDiv.appendChild(incSpan);
      rightDiv.appendChild(expSpan);
      rightDiv.appendChild(netSpan);
      rightDiv.appendChild(arrow);
      header.appendChild(titleSpan);
      header.appendChild(rightDiv);

      const detail = document.createElement("div");
      detail.className = "month-detail";

      // Income breakdown
      if (Object.keys(incCats).length > 0) {
        const it = document.createElement("div"); it.className = "cat-section-title"; it.textContent = "Income";
        detail.appendChild(it);
        Object.entries(incCats).sort((a,b) => b[1]-a[1]).forEach(([cat, amt]) => {
          const row = document.createElement("div"); row.className = "cat-row";
          const cn = document.createElement("span"); cn.className = "cat-name"; cn.textContent = cat;
          const ca = document.createElement("span"); ca.className = "cat-amt inc"; ca.textContent = "+₹" + amt.toFixed(2);
          row.appendChild(cn); row.appendChild(ca); detail.appendChild(row);
        });
      }

      // Expense breakdown with budget bars
      if (Object.keys(expCats).length > 0) {
        const et = document.createElement("div"); et.className = "cat-section-title"; et.textContent = "Expenses";
        detail.appendChild(et);
        const budgets = loadBudgets();
        Object.entries(expCats).sort((a,b) => b[1]-a[1]).forEach(([cat, amt]) => {
          const row = document.createElement("div"); row.className = "cat-row";
          row.style.flexDirection = "column"; row.style.alignItems = "stretch";
          const topRow = document.createElement("div");
          topRow.style.cssText = "display:flex;justify-content:space-between;";
          const cn = document.createElement("span"); cn.className = "cat-name"; cn.textContent = cat;
          const ca = document.createElement("span"); ca.className = "cat-amt exp"; ca.textContent = "-₹" + amt.toFixed(2);
          topRow.appendChild(cn); topRow.appendChild(ca);
          row.appendChild(topRow);
          // Budget bar if limit set
          const limit = budgets[cat];
          if (limit > 0) {
            const pct = Math.min(100, (amt / limit) * 100);
            const cls = pct >= 100 ? "over" : pct >= 80 ? "warn" : "ok";
            const barWrap = document.createElement("div"); barWrap.className = "budget-bar-wrap";
            const barBg = document.createElement("div"); barBg.className = "budget-bar-bg";
            const barFill = document.createElement("div");
            barFill.className = "budget-bar-fill " + cls;
            barFill.style.width = pct + "%";
            barBg.appendChild(barFill); barWrap.appendChild(barBg);
            const meta = document.createElement("div"); meta.className = "budget-meta";
            meta.innerHTML = "<span>₹" + amt.toFixed(0) + " / ₹" + limit.toFixed(0) + "</span><span>" + pct.toFixed(0) + "%</span>";
            barWrap.appendChild(meta); row.appendChild(barWrap);
          }
          detail.appendChild(row);
        });
      }

      header.addEventListener("click", () => {
        const open = detail.classList.toggle("open");
        arrow.style.transform = open ? "rotate(90deg)" : "";
      });

      block.appendChild(header);
      block.appendChild(detail);
      container.appendChild(block);
    }

    if (container.innerHTML === "") {
      container.innerHTML = '<p class="empty">No transactions for ' + activeYear + '</p>';
    }
  }

  function filterTransactions() {
    const from   = elFromDate.value;
    const to     = elToDate.value;
    const typeF  = ge("filterType") ? ge("filterType").value : "";
    const catF   = ge("filterCat")  ? ge("filterCat").value  : "";
    const query  = (ge("searchText") ? ge("searchText").value.trim().toLowerCase() : "");
    const hist   = ge("history");
    hist.innerHTML = "";

    let sorted = getSortedFiltered(from, to, typeF, catF);
    if (query) {
      sorted = sorted.filter(t =>
        (t.desc   || "").toLowerCase().includes(query) ||
        (t.person || "").toLowerCase().includes(query) ||
        (t.category|| "").toLowerCase().includes(query)
      );
    }

    // Totals row
    const totalsEl = ge("historyTotals");
    if (sorted.length > 0) {
      let tInc = 0, tExp = 0;
      sorted.forEach(t => { if (t.type === "income") tInc += t.amount; else tExp += t.amount; });
      const net = tInc - tExp;
      ge("htCount").textContent = sorted.length + " transaction" + (sorted.length !== 1 ? "s" : "");
      ge("htInc").textContent   = "+₹" + tInc.toFixed(2);
      ge("htExp").textContent   = "-₹" + tExp.toFixed(2);
      ge("htNet").textContent   = "Net: " + (net >= 0 ? "+" : "") + "₹" + net.toFixed(2);
      totalsEl.style.display = "flex";
    } else {
      totalsEl.style.display = "none";
    }

    if (sorted.length === 0) {
      const li = document.createElement("li");
      li.className = "empty"; li.textContent = "No transactions found";
      hist.appendChild(li); return;
    }
    sorted.forEach(t => {
      const origIndex = transactions.indexOf(t);
      hist.appendChild(buildTxItem(t, origIndex));
    });
  }

  function renderRecent() {
    const el     = ge("recentHistory");
    el.innerHTML = "";
    const sorted = getSortedFiltered("", "", "", "").slice(0, 5);
    if (sorted.length === 0) {
      const li = document.createElement("li");
      li.className = "empty"; li.textContent = "No transactions yet";
      el.appendChild(li); return;
    }
    sorted.forEach(t => {
      const origIndex = transactions.indexOf(t);
      el.appendChild(buildTxItem(t, origIndex));
    });
  }

