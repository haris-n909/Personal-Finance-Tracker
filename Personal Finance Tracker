  /* ─── TRASH ─── */
  function loadTrash() {
    try { const r = localStorage.getItem(TRASH_KEY); return r ? JSON.parse(r) : []; }
    catch(e) { return []; }
  }
  function saveTrash(arr) {
    // Purge items older than 30 days
    const cutoff = Date.now() - 30 * 24 * 60 * 60 * 1000;
    const pruned = arr.filter(t => t._deletedAt && t._deletedAt > cutoff);
    localStorage.setItem(TRASH_KEY, JSON.stringify(pruned));
  }
  function updateTrashBadge() {
    const trash = loadTrash();
    const badge = ge("trashBadge");
    if (!badge) return;
    if (trash.length > 0) {
      badge.textContent = trash.length;
      badge.style.display = "inline";
    } else {
      badge.style.display = "none";
    }
  }
  function renderTrash() {
    const list = ge("trashList");
    list.innerHTML = "";
    const trash = loadTrash();
    if (trash.length === 0) {
      const li = document.createElement("li"); li.className = "empty"; li.textContent = "Trash is empty";
      list.appendChild(li); return;
    }
    // Sort newest-deleted first
    [...trash].sort((a,b) => b._deletedAt - a._deletedAt).forEach((t, idx) => {
      const origIdx = trash.indexOf(t);
      const li = document.createElement("li"); li.className = "tx-item deleted-pending";
      const isIncome = t.type === "income";
      const iconDiv = document.createElement("div");
      iconDiv.className = "tx-icon " + t.type;
      iconDiv.textContent = isIncome ? "📈" : "📉";
      const infoDiv = document.createElement("div"); infoDiv.className = "tx-info";
      const topDiv = document.createElement("div"); topDiv.className = "tx-top";
      const catSpan = document.createElement("span"); catSpan.className = "tx-cat"; catSpan.textContent = t.category;
      const trashBadge = document.createElement("span"); trashBadge.className = "trash-badge"; trashBadge.textContent = "DELETED";
      topDiv.appendChild(catSpan); topDiv.appendChild(trashBadge);
      const metaDiv = document.createElement("div"); metaDiv.className = "tx-meta";
      const daysAgo = Math.floor((Date.now() - t._deletedAt) / (24*60*60*1000));
      const expires = 30 - daysAgo;
      metaDiv.textContent = t.date + (t.person ? " · 👤 " + t.person : "") + (t.desc ? " · " + t.desc : "") + " · expires in " + expires + "d";
      infoDiv.appendChild(topDiv); infoDiv.appendChild(metaDiv);
      const amtDiv = document.createElement("div");
      amtDiv.className = "tx-amount " + t.type;
      amtDiv.textContent = (isIncome ? "+" : "-") + "₹" + t.amount.toFixed(2);
      const actDiv = document.createElement("div"); actDiv.className = "tx-actions";
      const restoreBtn = document.createElement("button");
      restoreBtn.className = "restore-btn"; restoreBtn.textContent = "↩ Restore";
      restoreBtn.addEventListener("click", () => {
        const tr = loadTrash(); const item = tr[origIdx];
        if (!item) return;
        tr.splice(origIdx, 1); saveTrash(tr);
        const { _deletedAt, ...clean } = item;
        transactions.push(clean);
        apply(clean);
        saveData(); updateAll(); renderTrash();
      });
      const permDelBtn = document.createElement("button");
      permDelBtn.className = "btn btn-danger btn-sm"; permDelBtn.textContent = "✕";
      permDelBtn.title = "Permanently delete";
      permDelBtn.addEventListener("click", () => {
        if (!confirm("Permanently delete this transaction? Cannot be undone.")) return;
        const tr = loadTrash(); tr.splice(origIdx, 1); saveTrash(tr); renderTrash(); updateTrashBadge();
      });
      actDiv.appendChild(restoreBtn); actDiv.appendChild(permDelBtn);
      li.appendChild(iconDiv); li.appendChild(infoDiv); li.appendChild(amtDiv); li.appendChild(actDiv);
      list.appendChild(li);
    });
  }
  function emptyTrash() {
