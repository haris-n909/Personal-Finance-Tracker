<script>
/* ─── STATE ─── */
let balance = 0, youOwe = 0, othersOwe = 0, investments = 0, totalGift = 0;
let transactions = [], borrowedMap = {}, lentMap = {}, giftMap = {};
let editIndex = null;
let currentPage = "dashboard";

const STORAGE_KEY       = "financeTrackerData";
const SETUP_DONE_KEY   = "financeTrackerSetupDone";
const INITIAL_DATA_KEY = "financeTrackerInitial";
const TRASH_KEY        = "financeTrackerTrash";
const TEMPLATES_KEY    = "financeTrackerTemplates";
const BUDGETS_KEY      = "financeTrackerBudgets";
const DARK_KEY         = "financeTrackerDark";
const PERSON_CATS       = ["Borrowed","Lent Repayment","Lent","Debt Repayment","Gift"];
const INCOME_CATS       = ["Salary","Business","Borrowed","Lent Repayment","Gift Received","Other"];
const EXPENSE_CATS      = ["Food","Family","Shopping","Travel","Bills","Recharge","Lent",
                           "Debt Repayment","Investment","Tea","Gift","Entertainment","Education","Other"];

document.addEventListener("DOMContentLoaded", function () {

  const ge = id => document.getElementById(id);

  const elDate      = ge("date");
  const elDay       = ge("day");
  const elAmount    = ge("amount");
  const elType      = ge("type");
  const elCat       = ge("category");
  const elPersonDiv = ge("personDiv");
  const elPerson    = ge("person");
  const elPersonSel = ge("personSelect");
  const elDesc      = ge("desc");
  const elFormTitle = ge("formTitle");
  const elUpdateBtn = ge("updateBtn");
  const elCancelBtn = ge("cancelBtn");
  const elFromDate  = ge("fromDate");
  const elToDate    = ge("toDate");


  /* ─── NAVIGATION ─── */
  function showPage(name) {
    document.querySelectorAll(".page").forEach(p => p.classList.remove("active"));
    ge("page-" + name).classList.add("active");
    document.querySelectorAll(".nav-item[data-page]")
      .forEach(el => el.classList.toggle("active", el.dataset.page === name));
    document.querySelectorAll(".bn-item[data-page]")
      .forEach(el => el.classList.toggle("active", el.dataset.page === name));
    currentPage = name;
    closeSidebar();
    if (name === "history")   { populateCatFilter(); filterTransactions(); }
    if (name === "dashboard") renderRecent();
    if (name === "initial")   renderInitialPage();
    if (name === "monthly")   renderMonthlySummary();
    if (name === "recurring") renderTemplates();
    if (name === "budget")    renderBudgetPage();
    if (name === "trash")     renderTrash();
  }

  function toggleSidebar() {
    ge("sidebar").classList.toggle("open");
    ge("overlay").classList.toggle("open");
  }
  function closeSidebar() {
    ge("sidebar").classList.remove("open");
    ge("overlay").classList.remove("open");
  }

  /* ─── CATEGORIES ─── */
  function updateCategories() {
    elCat.innerHTML = "";
    (elType.value === "income" ? INCOME_CATS : EXPENSE_CATS).forEach(c => {
      const o = document.createElement("option");
      o.value = o.textContent = c;
      elCat.appendChild(o);
    });
    togglePersonField();
  }

  function togglePersonField() {
    const type = elType.value;
    const cat  = elCat.value;

    elPersonDiv.style.display       = "none";
    elPerson.value                  = "";
    elPersonSel.innerHTML           = "";
    elPersonSel.style.display       = "none";
    elPerson.style.display          = "block";

    const need = (type === "income"  && (cat === "Borrowed" || cat === "Lent Repayment")) ||
                 (type === "expense" && (cat === "Lent" || cat === "Debt Repayment" || cat === "Gift"));

    if (!need) return;

    elPersonDiv.style.display = "block";

    if (cat === "Lent Repayment" || cat === "Debt Repayment") {
      const map    = cat === "Lent Repayment" ? lentMap : borrowedMap;
      const people = Object.keys(map).filter(p => map[p] > 0);
      if (people.length > 0) {
        elPersonSel.innerHTML = "";
        people.forEach(p => {
          const o = document.createElement("option");
          o.value = p;
          o.textContent = `${p} (₹${map[p].toFixed(2)})`;
          elPersonSel.appendChild(o);
        });
        const other = document.createElement("option");
        other.value = "Other"; other.textContent = "Other (New)";
        elPersonSel.appendChild(other);
        elPersonSel.style.display = "block";
        elPerson.style.display    = "none";
        elPerson.value            = "";
      } else {
        elPersonSel.style.display = "none";
        elPerson.style.display    = "block";
      }
    } else {
      elPersonSel.style.display = "none";
      elPerson.style.display    = "block";
    }
  }

  function updateDay() {
    const d = elDate.value;
    if (!d) { elDay.value = ""; return; }
    const days = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
    elDay.value = days[new Date(d + "T00:00:00").getDay()];
  }

  function getPerson() {
    if (elPersonSel.style.display === "block") {
      return elPersonSel.value === "Other" ? elPerson.value.trim() : elPersonSel.value;
    }
    return elPerson.value.trim();
  }

  /* ─── FORM DATA ─── */
  function getFormData() {
    const date   = elDate.value.trim();
    const amount = parseFloat(elAmount.value);
    const type   = elType.value;
    const cat    = elCat.value;
    const person = getPerson();
    const desc   = elDesc.value.trim();

    if (!date) { alert("Please select a date."); return null; }
    if (isNaN(amount) || amount <= 0) { alert("Please enter a valid amount greater than 0."); return null; }

    const needsPerson =
      (type === "income"  && (cat === "Borrowed" || cat === "Lent Repayment")) ||
      (type === "expense" && (cat === "Lent" || cat === "Debt Repayment" || cat === "Gift"));
    if (needsPerson && !person) { alert("Please enter a person name."); return null; }

    return { date, day: elDay.value, amount, type, category: cat, person, desc };
  }

  /* ─── APPLY / REVERT ─── */
  function apply(t) {
    if (t.type === "income") {
      if (t.category === "Borrowed") {
        balance += t.amount;
        youOwe += t.amount;
        borrowedMap[t.person] = (borrowedMap[t.person] || 0) + t.amount;
      }
      if (t.category === "Lent Repayment") {
        balance += t.amount;
        othersOwe = Math.max(0, othersOwe - t.amount);
        if (t.person) lentMap[t.person] = Math.max(0, (lentMap[t.person] || 0) - t.amount);
      }

      if (t.category === "Gift Received") { balance += t.amount; }
      if (t.category === "Salary" || t.category === "Business" || t.category === "Other") {
        balance += t.amount;
      }
    } else {
      balance -= t.amount;
      if (t.category === "Lent") {
        othersOwe += t.amount;
        lentMap[t.person] = (lentMap[t.person] || 0) + t.amount;
      }
      if (t.category === "Debt Repayment") {
        youOwe = Math.max(0, youOwe - t.amount);
        if (t.person) borrowedMap[t.person] = Math.max(0, (borrowedMap[t.person] || 0) - t.amount);
      }
      if (t.category === "Investment") investments += t.amount;
      if (t.category === "Gift") {
        totalGift += t.amount;
        if (t.person) giftMap[t.person] = (giftMap[t.person] || 0) + t.amount;
      }

    }
  }

  function revert(t) {
    if (t.type === "income") {
      if (t.category === "Borrowed") {
        balance -= t.amount;
        youOwe = Math.max(0, youOwe - t.amount);
        if (t.person) borrowedMap[t.person] = Math.max(0, (borrowedMap[t.person] || 0) - t.amount);
      }
      if (t.category === "Lent Repayment") {
        balance -= t.amount;
        othersOwe += t.amount;
        if (t.person) lentMap[t.person] = (lentMap[t.person] || 0) + t.amount;
      }

      if (t.category === "Gift Received") { balance -= t.amount; }
      if (t.category === "Salary" || t.category === "Business" || t.category === "Other") {
        balance -= t.amount;
      }
    } else {
      balance += t.amount;
      if (t.category === "Lent") {
        othersOwe = Math.max(0, othersOwe - t.amount);
        if (t.person) lentMap[t.person] = Math.max(0, (lentMap[t.person] || 0) - t.amount);
      }
      if (t.category === "Debt Repayment") {
        youOwe += t.amount;
        if (t.person) borrowedMap[t.person] = (borrowedMap[t.person] || 0) + t.amount;
      }
      if (t.category === "Investment") investments = Math.max(0, investments - t.amount);
      if (t.category === "Gift") {
        totalGift = Math.max(0, totalGift - t.amount);
        if (t.person) giftMap[t.person] = Math.max(0, (giftMap[t.person] || 0) - t.amount);
      }

    }
  }

  /* ─── CRUD ─── */
  function addTransaction() {
    const t = getFormData();
    if (!t) return;
    transactions.push(t);
    apply(t);
    saveData();
    updateAll();
  }

  function updateTransaction() {
    if (editIndex === null) return;
    const t = getFormData();
    if (!t) return;
    revert(transactions[editIndex]);
    transactions[editIndex] = t;
    apply(t);
    saveData();
    editIndex = null;
    elUpdateBtn.style.display = "none";
    elCancelBtn.style.display = "none";
    elFormTitle.textContent   = "➕ Add Transaction";
    updateAll();
  }

  function editTransaction(i) {
    if (i < 0 || i >= transactions.length) return;
    const t = transactions[i];
    editIndex = i;
    elDate.value     = t.date;    updateDay();
    elAmount.value   = t.amount;
    elType.value     = t.type;    updateCategories();
    elCat.value      = t.category; togglePersonField();

    if (t.person) {
        if (elPersonSel.style.display === "block") {
          const exists = Array.from(elPersonSel.options).some(o => o.value === t.person);
          if (exists) elPersonSel.value = t.person;
          else {
            elPersonSel.value  = "Other";
            elPerson.style.display = "block";
            elPerson.value     = t.person;
          }
        } else {
          elPerson.value = t.person;
        }
      }

    elDesc.value = t.desc || "";
    elUpdateBtn.style.display = "inline-flex";
    elCancelBtn.style.display = "inline-flex";
    elFormTitle.textContent   = "✏️ Edit Transaction";
    showPage("add");
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function deleteTransaction(i) {
    if (i < 0 || i >= transactions.length) return;
    if (!confirm("Move this transaction to Trash? You can restore it within 30 days.")) return;
    const t = transactions[i];
    revert(t);
    transactions.splice(i, 1);
    // Add to trash with deletion timestamp
    const trash = loadTrash();
    trash.push({ ...t, _deletedAt: Date.now() });
    saveTrash(trash);
    saveData();
    updateAll();
    updateTrashBadge();
  }

  function cancelEdit() {
    editIndex = null;
    elUpdateBtn.style.display = "none";
    elCancelBtn.style.display = "none";
    elFormTitle.textContent   = "➕ Add Transaction";
    clearForm();
  }

  /* ─── RENDER ─── */
  function buildTxItem(t, origIndex) {
    const li       = document.createElement("li");
    li.className   = "tx-item";
    const isIncome = t.type === "income";
    const meta     = [`${t.date} (${t.day || ""})`];
    if (PERSON_CATS.includes(t.category) && t.person) {
      meta.push("👤 " + t.person);
    }
    if (t.desc) meta.push("📝 " + t.desc);

    const iconDiv = document.createElement("div");
    iconDiv.className = "tx-icon " + t.type;
    iconDiv.textContent = isIncome ? "📈" : "📉";

    const infoDiv = document.createElement("div");
    infoDiv.className = "tx-info";

    const topDiv = document.createElement("div");
    topDiv.className = "tx-top";

    const catSpan = document.createElement("span");
    catSpan.className = "tx-cat";
    catSpan.textContent = t.category;

    const badgeSpan = document.createElement("span");
    badgeSpan.className = "tx-badge " + t.type;
    badgeSpan.textContent = t.type.toUpperCase();

    topDiv.appendChild(catSpan);
    topDiv.appendChild(badgeSpan);

    const metaDiv = document.createElement("div");
    metaDiv.className = "tx-meta";
    metaDiv.textContent = meta.join(" · ");

    infoDiv.appendChild(topDiv);
    infoDiv.appendChild(metaDiv);

    // Running balance — computed lazily via data attribute set by caller
    if (typeof origIndex === "number") {
      const runBal = computeRunningBalance(origIndex);
      if (runBal !== null) {
        const rbDiv = document.createElement("div");
        rbDiv.className = "tx-running";
        rbDiv.textContent = "Balance after: ₹" + runBal.toFixed(2);
        infoDiv.appendChild(rbDiv);
      }
    }

    const amountDiv = document.createElement("div");
    amountDiv.className = "tx-amount " + t.type;
    amountDiv.textContent = (isIncome ? "+" : "-") + "₹" + t.amount.toFixed(2);

    const actionsDiv = document.createElement("div");
    actionsDiv.className = "tx-actions";

    const eb = document.createElement("button");
    eb.className   = "btn btn-primary btn-sm";
    eb.textContent = "Edit";
    eb.addEventListener("click", () => editTransaction(origIndex));

    const db = document.createElement("button");
    db.className   = "btn btn-danger btn-sm";
    db.textContent = "Del";
    db.addEventListener("click", () => deleteTransaction(origIndex));

    actionsDiv.appendChild(eb);
    actionsDiv.appendChild(db);

    li.appendChild(iconDiv);
    li.appendChild(infoDiv);
    li.appendChild(amountDiv);
    li.appendChild(actionsDiv);
    return li;
  }

  function getSortedFiltered(from, to, typeF, catF) {
    return [...transactions]
      .sort((a, b) => {
        const dc = new Date(b.date) - new Date(a.date);
        return dc !== 0 ? dc : transactions.indexOf(b) - transactions.indexOf(a);
      })
      .filter(t => {
        if (from && t.date < from) return false;
        if (to   && t.date > to)   return false;
        if (typeF && t.type     !== typeF) return false;
        if (catF  && t.category !== catF)  return false;
        return true;
      });
  }

  // Compute running cash balance after transaction at index i
  // (sorted chronologically, same order as transactions array after loadData sorts it)
  // Cached initial balance for running balance computation — avoid repeated localStorage reads
  let _cachedInitBalance = null;
  function getInitBalanceCache() {
    if (_cachedInitBalance === null) {
      const d = loadInitialData();
      _cachedInitBalance = d ? (parseFloat(d.balance) || 0) : 0;
    }
    return _cachedInitBalance;
  }
  function invalidateInitBalanceCache() { _cachedInitBalance = null; }

  function computeRunningBalance(idx) {
    // Sum only balance-affecting transactions in chronological order up to idx.
    let bal = getInitBalanceCache();
    for (let i = 0; i <= idx; i++) {
      const t = transactions[i];
      if (!t) continue;
      if (t.type === "income") bal += t.amount;
      else bal -= t.amount;
    }
    return bal;
  }

  // Populate category filter dropdown
  function populateCatFilter() {
    const sel = ge("filterCat");
