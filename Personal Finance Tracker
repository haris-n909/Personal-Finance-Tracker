  // Apply initial data directly to aggregate state (NO transactions pushed).
  // This keeps history clean.
  function applyInitialData(data) {
    const b = parseFloat(data.balance)    || 0;
    const i = parseFloat(data.investment) || 0;
    balance     += b;
    investments += i;

    (data.debts || []).forEach(({ name, amount }) => {
      if (!name || amount <= 0) return;
      youOwe += amount;
      borrowedMap[name] = (borrowedMap[name] || 0) + amount;
    });
    (data.lents || []).forEach(({ name, amount }) => {
      if (!name || amount <= 0) return;
      othersOwe += amount;
      lentMap[name] = (lentMap[name] || 0) + amount;
    });
    (data.gifts || []).forEach(({ name, amount }) => {
      if (!name || amount <= 0) return;
      totalGift += amount;
      giftMap[name] = (giftMap[name] || 0) + amount;
    });
  }

