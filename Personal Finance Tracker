  /* ─── NET SETTLEMENT (debt netting) ─── */
  function renderNetSettlement() {
    const card = ge("netSettlementCard");
    const list = ge("netSettlementList");
    if (!card || !list) return;
    list.innerHTML = "";
    // Find people who appear in both borrowed and lent
    const borrowPeople = {};
    for (const k in borrowedMap) {
      if (borrowedMap[k] > 0) borrowPeople[k] = borrowedMap[k];
    }
    const lentPeople = {};
    for (const k in lentMap) {
      if (lentMap[k] > 0) lentPeople[k] = lentMap[k];
    }
    const allPeople = new Set([...Object.keys(borrowPeople), ...Object.keys(lentPeople)]);
    const nets = [];
    allPeople.forEach(p => {
      const owe  = borrowPeople[p] || 0;  // you owe them
      const owed = lentPeople[p]   || 0;  // they owe you
      if (owe > 0 && owed > 0) {
        nets.push({ person: p, owe, owed, net: owed - owe });
      }
    });
    if (nets.length === 0) { card.style.display = "none"; return; }
    card.style.display = "block";
    nets.sort((a,b) => a.person.localeCompare(b.person)).forEach(({ person, owe, owed, net }) => {
      const row = document.createElement("div"); row.className = "person-item";
      const nameSpan = document.createElement("span"); nameSpan.className = "pname"; nameSpan.textContent = person;
      const badge = document.createElement("span");
      badge.className = "net-badge " + (net >= 0 ? "owed" : "owe");
      badge.textContent = net >= 0
        ? "they owe you ₹" + net.toFixed(2)
        : "you owe ₹" + Math.abs(net).toFixed(2);
      const detail = document.createElement("span");
      detail.style.cssText = "font-size:11px;color:var(--muted);margin-left:8px;";
      detail.textContent = "(borrowed ₹" + owe.toFixed(0) + " · lent ₹" + owed.toFixed(0) + ")";
      row.appendChild(nameSpan); row.appendChild(badge); row.appendChild(detail);
      list.appendChild(row);
    });
  }

  /* ─── MONTHLY XLSX EXPORT ─── */
  function exportMonthlySummary() {
    const yearSel = ge("monthlyYear");
    const activeYear = yearSel.value || String(new Date().getFullYear());
    const MONTHS = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    const rows = [];
    for (let m = 0; m < 12; m++) {
      const prefix = activeYear + "-" + String(m + 1).padStart(2, "0");
      const monthTxs = transactions.filter(t => t.date && t.date.startsWith(prefix));
      if (monthTxs.length === 0) continue;
      let tInc = 0, tExp = 0;
      const incCats = {}, expCats = {};
      monthTxs.forEach(t => {
        if (t.type === "income") { tInc += t.amount; incCats[t.category] = (incCats[t.category]||0)+t.amount; }
        else { tExp += t.amount; expCats[t.category] = (expCats[t.category]||0)+t.amount; }
      });
      rows.push({ "Month": MONTHS[m]+" "+activeYear, "Category": "TOTAL INCOME", "Amount": tInc });
      Object.entries(incCats).sort((a,b)=>b[1]-a[1]).forEach(([cat,amt]) => {
        rows.push({ "Month": "", "Category": cat, "Amount": amt });
      });
      rows.push({ "Month": "", "Category": "TOTAL EXPENSE", "Amount": -tExp });
      Object.entries(expCats).sort((a,b)=>b[1]-a[1]).forEach(([cat,amt]) => {
        rows.push({ "Month": "", "Category": cat, "Amount": -amt });
      });
      rows.push({ "Month": "", "Category": "NET", "Amount": tInc - tExp });
      rows.push({ "Month": "", "Category": "", "Amount": "" });
    }
    if (rows.length === 0) { alert("No data for " + activeYear); return; }
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(rows), "Monthly Summary");
    XLSX.writeFile(wb, "Monthly_Summary_" + activeYear + ".xlsx");
  }

  /* ─── INIT ─── */
  loadData();
  const initData = loadInitialData();
  if (initData) applyInitialData(initData);
  clearForm();
  updateUI();
  renderRecent();
  initDark();
  updateTrashBadge();
  showSetupIfNeeded();

});
</script>
