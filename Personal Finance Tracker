<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Personal Finance Tracker</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root {
  --primary:#1a73e8; --primary-dark:#1557b0;
  --success:#34a853; --danger:#ea4335;
  --warning:#f57c00; --purple:#7b2ff7;
  --bg:#f0f4f9; --card:#fff;
  --text:#202124; --muted:#5f6368; --border:#dadce0;
  --sidebar-w:240px; --header-h:56px; --bottom-nav-h:60px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Segoe UI',Arial,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}

.header{
  position:fixed;top:0;left:0;right:0;height:var(--header-h);
  background:var(--primary);color:white;
  display:flex;align-items:center;padding:0 16px;
  z-index:300;box-shadow:0 2px 6px rgba(0,0,0,0.25);gap:12px;
}
.header h1{font-size:18px;font-weight:600;flex:1;}
.hamburger{
  display:none;background:none;border:none;
  color:white;font-size:24px;cursor:pointer;padding:4px 8px;line-height:1;
}

.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:190;}
.overlay.open{display:block;}

.sidebar{
  position:fixed;top:var(--header-h);left:0;bottom:0;
  width:var(--sidebar-w);background:white;
  border-right:1px solid var(--border);
  z-index:200;overflow-y:auto;padding:12px 0;
  transition:transform 0.25s ease;
}
.nav-section-label{
  padding:10px 16px 4px;font-size:10px;font-weight:700;
  color:#aaa;text-transform:uppercase;letter-spacing:1px;
}
.nav-divider{border:none;border-top:1px solid var(--border);margin:6px 0;}
.nav-item{
  display:flex;align-items:center;gap:12px;
  padding:11px 18px;cursor:pointer;
  color:var(--muted);font-size:14px;font-weight:500;
  border-left:3px solid transparent;
  transition:all 0.15s;user-select:none;
}
.nav-item:hover{background:#f1f3f4;color:var(--text);}
.nav-item.active{background:#e8f0fe;color:var(--primary);border-left-color:var(--primary);font-weight:600;}
.nav-item .nav-icon{font-size:18px;width:22px;text-align:center;}

.main{
  margin-left:var(--sidebar-w);
  margin-top:var(--header-h);
  padding:24px;
  min-height:calc(100vh - var(--header-h));
}

.page{display:none;}
.page.active{display:block;}

.summary-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(155px,1fr));
  gap:14px;margin-bottom:18px;
}
.tile{
  background:white;border-radius:12px;
  padding:16px 18px;box-shadow:0 1px 4px rgba(0,0,0,0.08);
  border-top:3px solid var(--primary);
}
.tile.red   {border-top-color:var(--danger);}
.tile.green {border-top-color:var(--success);}
.tile.orange{border-top-color:var(--warning);}
.tile.purple{border-top-color:var(--purple);}
.tile label {font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;display:block;}
.tile .val  {font-size:22px;font-weight:700;margin-top:4px;}

.networth-bar{
  background:white;border-radius:12px;
  padding:16px 22px;box-shadow:0 1px 4px rgba(0,0,0,0.08);
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:18px;
}
.networth-bar .nw-label{font-size:15px;font-weight:600;color:var(--muted);}
.nwval{font-size:26px;font-weight:700;color:var(--success);}
.nwval.neg{color:var(--danger);}

.card{
  background:white;border-radius:12px;
  box-shadow:0 1px 4px rgba(0,0,0,0.08);
  padding:20px 22px;margin-bottom:18px;
}
.card-title{
  font-size:12px;font-weight:700;color:var(--muted);
  text-transform:uppercase;letter-spacing:0.8px;
  margin-bottom:14px;padding-bottom:10px;
  border-bottom:1px solid var(--border);
}

.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px 22px;}
.form-group{display:flex;flex-direction:column;gap:5px;}
.form-group label{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;}
.form-group input,
.form-group select,
.form-group textarea{
  padding:10px 12px;border:1px solid var(--border);
  border-radius:8px;font-size:14px;color:var(--text);
  background:#fafafa;font-family:inherit;width:100%;
  transition:border 0.2s,box-shadow 0.2s;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus{
  outline:none;border-color:var(--primary);
  box-shadow:0 0 0 3px rgba(26,115,232,0.12);background:white;
}
.form-group textarea{resize:vertical;min-height:70px;}
.form-full{grid-column:1 / -1;}
.form-actions{display:flex;gap:10px;margin-top:12px;flex-wrap:wrap;}

.btn{
  padding:10px 18px;border:none;border-radius:8px;
  font-size:14px;font-weight:600;cursor:pointer;
  display:inline-flex;align-items:center;gap:6px;
  transition:opacity 0.2s,transform 0.1s;white-space:nowrap;
}
.btn:hover{opacity:0.88;}
.btn:active{transform:scale(0.97);}
.btn-primary{background:var(--primary);color:white;}
.btn-success{background:var(--success);color:white;}
.btn-danger {background:var(--danger); color:white;}
.btn-warning{background:var(--warning);color:white;}
.btn-purple {background:var(--purple); color:white;}
.btn-muted  {background:#e8eaed;color:var(--text);}
.btn-sm{padding:6px 13px;font-size:12px;border-radius:6px;}

.person-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;}
.person-section h4{font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;}
.person-item{
  display:flex;justify-content:space-between;align-items:center;
  padding:8px 12px;background:#f8f9fa;
  border-radius:8px;margin-bottom:6px;font-size:14px;
}
.person-item .pname {font-weight:500;}
.person-item .pamount{font-weight:700;color:var(--primary);}
.person-item .expand-btn{
  background:none;border:none;color:var(--primary);
  cursor:pointer;font-size:16px;padding:4px 8px;
  transition:transform 0.2s;
}
.person-item .expand-btn:hover{opacity:0.7;}
.person-item .expand-btn.expanded{transform:rotate(90deg);}
.person-sublist{
  margin-left:20px;margin-top:6px;
  padding-left:12px;border-left:2px solid #e0e0e0;
}
.person-subitem{
  padding:6px 8px;font-size:13px;color:var(--muted);
  display:flex;justify-content:space-between;
  margin-bottom:4px;
}
.person-subitem.borrowed{color:var(--success);}
.person-subitem.repaid{color:var(--danger);}
.person-subitem.lent{color:var(--danger);}
.person-subitem.repayment{color:var(--success);}

.filter-bar{display:flex;flex-wrap:wrap;align-items:center;gap:8px;margin-bottom:16px;}
.filter-bar input{
  padding:8px 12px;border:1px solid var(--border);
  border-radius:8px;font-size:14px;background:#fafafa;
}
.filter-bar input:focus{outline:none;border-color:var(--primary);}
.filter-label{font-size:13px;font-weight:600;color:var(--muted);}

.tx-list{list-style:none;padding:0;}
.tx-item{
  display:flex;align-items:center;gap:12px;
  padding:12px 14px;border-radius:10px;margin-bottom:8px;
  background:#fafafa;border:1px solid var(--border);
  transition:box-shadow 0.15s;
}
.tx-item:hover{box-shadow:0 2px 8px rgba(0,0,0,0.08);}
.tx-icon{
  width:38px;height:38px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:17px;flex-shrink:0;
}
.tx-icon.income {background:#e6f4ea;}
.tx-icon.expense{background:#fce8e6;}
.tx-info{flex:1;min-width:0;}
.tx-top{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.tx-cat{font-size:14px;font-weight:600;}
.tx-badge{font-size:11px;padding:2px 8px;border-radius:20px;font-weight:600;background:#e8f0fe;color:var(--primary);}
.tx-badge.expense{background:#fce8e6;color:var(--danger);}
.tx-meta{font-size:12px;color:var(--muted);margin-top:3px;}
.tx-amount{font-size:15px;font-weight:700;flex-shrink:0;}
.tx-amount.income {color:var(--success);}
.tx-amount.expense{color:var(--danger);}
.tx-actions{display:flex;gap:6px;flex-shrink:0;}
.empty{color:var(--muted);font-size:14px;padding:20px;text-align:center;}

/* ── MONTHLY SUMMARY ── */
.month-block{margin-bottom:20px;border:1px solid var(--border);border-radius:10px;overflow:hidden;}
.month-header{
  display:flex;justify-content:space-between;align-items:center;
  padding:12px 16px;background:#f8f9fa;cursor:pointer;
  font-weight:600;font-size:14px;
}
.month-header:hover{background:#f1f3f4;}
.month-header .mh-right{display:flex;gap:16px;align-items:center;font-size:13px;}
.month-header .mh-inc{color:var(--success);}
.month-header .mh-exp{color:var(--danger);}
.month-header .mh-net{font-weight:700;}
.month-header .mh-net.pos{color:var(--success);}
.month-header .mh-net.neg{color:var(--danger);}
.month-detail{display:none;padding:12px 16px;border-top:1px solid var(--border);}
.month-detail.open{display:block;}
.cat-row{display:flex;justify-content:space-between;padding:5px 0;font-size:13px;border-bottom:1px solid #f1f3f4;}
.cat-row:last-child{border-bottom:none;}
.cat-row .cat-name{color:var(--muted);}
.cat-row .cat-amt{font-weight:600;}
.cat-row .cat-amt.inc{color:var(--success);}
.cat-row .cat-amt.exp{color:var(--danger);}
.cat-section-title{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin:10px 0 6px;}
/* ── RUNNING BALANCE ── */
.tx-running{font-size:11px;color:var(--muted);margin-top:2px;}

/* ── SETUP PAGE ── */
.setup-overlay{
  position:fixed;inset:0;background:var(--bg);
  z-index:9999;overflow-y:auto;
  display:flex;align-items:flex-start;justify-content:center;
  padding:32px 16px 40px;
}
.setup-overlay.hidden{display:none;}
.setup-box{width:100%;max-width:600px;}
.setup-header{
  text-align:center;margin-bottom:28px;
}
.setup-header .setup-icon{font-size:48px;display:block;margin-bottom:10px;}
.setup-header h2{font-size:22px;font-weight:700;color:var(--text);}
.setup-header p{font-size:13px;color:var(--muted);margin-top:6px;}

.setup-section{
  background:white;border-radius:12px;
  box-shadow:0 1px 4px rgba(0,0,0,0.08);
  padding:18px 20px;margin-bottom:16px;
}
.setup-section-title{
  font-size:11px;font-weight:700;color:var(--muted);
  text-transform:uppercase;letter-spacing:0.8px;
  margin-bottom:14px;padding-bottom:10px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:8px;
}
.setup-row{
  display:grid;grid-template-columns:1fr 1fr;
  gap:12px 18px;margin-bottom:12px;
}
.setup-person-list{margin-top:8px;}
.setup-person-entry{
  display:grid;grid-template-columns:1fr 1fr auto;
  gap:8px;align-items:center;margin-bottom:8px;
}
.setup-person-entry input{
  padding:9px 11px;border:1px solid var(--border);
  border-radius:8px;font-size:13px;color:var(--text);
  background:#fafafa;width:100%;
}
.setup-person-entry input:focus{
  outline:none;border-color:var(--primary);
  box-shadow:0 0 0 3px rgba(26,115,232,0.12);background:white;
}
.setup-add-row{
  display:flex;align-items:center;gap:8px;margin-top:4px;
}
.btn-add-person{
  background:none;border:1px dashed var(--border);
  border-radius:8px;color:var(--primary);font-size:13px;
  font-weight:600;padding:8px 14px;cursor:pointer;
  display:flex;align-items:center;gap:6px;
  transition:background 0.15s,border-color 0.15s;
}
.btn-add-person:hover{background:#f0f4ff;border-color:var(--primary);}
.btn-remove{
  background:none;border:none;color:var(--danger);
  font-size:18px;cursor:pointer;padding:4px 6px;line-height:1;
  border-radius:6px;flex-shrink:0;
}
.btn-remove:hover{background:#fce8e6;}
.setup-proceed{
  width:100%;padding:14px;font-size:16px;font-weight:700;
  background:var(--primary);color:white;border:none;
  border-radius:12px;cursor:pointer;margin-top:4px;
  display:flex;align-items:center;justify-content:center;gap:8px;
  transition:opacity 0.2s,transform 0.1s;
}
.setup-proceed:hover{opacity:0.88;}
.setup-proceed:active{transform:scale(0.98);}
.setup-skip{
  display:block;text-align:center;margin-top:12px;
  font-size:13px;color:var(--muted);cursor:pointer;
  text-decoration:underline;background:none;border:none;
}
.setup-skip:hover{color:var(--text);}


/* ── DARK MODE ── */
body.dark{
  --primary:#4a9eff;--primary-dark:#2176d2;
  --success:#4caf7d;--danger:#f06b6b;
  --warning:#ffb74d;--purple:#b47aff;
  --bg:#1a1b1e;--card:#25262b;
  --text:#e8e9ec;--muted:#9a9ba3;--border:#3a3b42;
}
body.dark .header{background:#1a1b1e;border-bottom:1px solid var(--border);}
body.dark .sidebar{background:var(--card);}
body.dark .setup-overlay{background:var(--bg);}
body.dark .setup-section{background:var(--card);}
body.dark .tx-item{background:var(--card);}
body.dark .person-item{background:#2e2f36;}
body.dark .month-block{border-color:var(--border);}
body.dark .month-header{background:#2e2f36;}
body.dark .filter-bar input,body.dark .filter-bar select{background:var(--card);color:var(--text);border-color:var(--border);}
body.dark .form-group input,body.dark .form-group select,body.dark .form-group textarea{background:var(--card);color:var(--text);border-color:var(--border);}
body.dark .tile{background:var(--card);}
body.dark .networth-bar{background:var(--card);}
body.dark .card{background:var(--card);}
body.dark .btn-muted{background:#3a3b42;color:var(--text);}
body.dark .bn-item{color:var(--muted);}
body.dark .bn-item.active{color:var(--primary);}
body.dark .bottom-nav{background:var(--card);border-top-color:var(--border);}
.dark-toggle{background:none;border:none;color:white;font-size:20px;cursor:pointer;padding:4px 6px;line-height:1;}

/* ── SEARCH BAR ── */
.search-wrap{position:relative;flex:1;min-width:160px;}
.search-wrap input{padding:8px 12px 8px 34px;border:1px solid var(--border);border-radius:8px;font-size:14px;background:#fafafa;width:100%;}
body.dark .search-wrap input{background:var(--card);color:var(--text);border-color:var(--border);}
.search-wrap input:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px rgba(26,115,232,0.12);background:white;}
body.dark .search-wrap input:focus{background:var(--card);}
.search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:14px;pointer-events:none;}
.history-totals{
  display:flex;gap:16px;flex-wrap:wrap;
  padding:10px 14px;background:#f0f4f9;border-radius:8px;
  margin-bottom:12px;font-size:13px;font-weight:600;
}
body.dark .history-totals{background:#2e2f36;}
.history-totals .ht-inc{color:var(--success);}
.history-totals .ht-exp{color:var(--danger);}
.history-totals .ht-count{color:var(--muted);}

/* ── BUDGET ── */
.budget-bar-wrap{margin-top:6px;}
.budget-bar-bg{height:6px;background:#e8eaed;border-radius:4px;overflow:hidden;margin-top:3px;}
body.dark .budget-bar-bg{background:#3a3b42;}
.budget-bar-fill{height:100%;border-radius:4px;transition:width 0.4s;}
.budget-bar-fill.ok{background:var(--success);}
.budget-bar-fill.warn{background:var(--warning);}
.budget-bar-fill.over{background:var(--danger);}
.budget-meta{font-size:11px;color:var(--muted);margin-top:2px;display:flex;justify-content:space-between;}

/* ── SOFT DELETE ── */
.tx-item.deleted-pending{opacity:0.55;border-color:var(--danger);border-style:dashed;}
.trash-badge{font-size:11px;padding:2px 7px;border-radius:20px;background:#fce8e6;color:var(--danger);font-weight:600;margin-left:6px;}
.restore-btn{color:var(--success);font-size:12px;font-weight:600;background:none;border:none;cursor:pointer;padding:4px 8px;border-radius:6px;}
.restore-btn:hover{background:#e6f4ea;}
.trash-notice{font-size:12px;color:var(--muted);padding:8px 14px;background:#fce8e6;border-radius:8px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center;}
body.dark .trash-notice{background:#3a2020;}

/* ── RECURRING ── */
.template-item{
  display:flex;align-items:center;gap:10px;
  padding:10px 12px;border-radius:8px;
  background:#f8f9fa;border:1px solid var(--border);
  margin-bottom:8px;font-size:13px;
}
body.dark .template-item{background:#2e2f36;}
.template-item .tpl-name{font-weight:600;flex:1;}
.template-item .tpl-meta{color:var(--muted);font-size:12px;}
.template-item .tpl-amt{font-weight:700;margin-right:8px;}
.template-item .tpl-amt.income{color:var(--success);}
.template-item .tpl-amt.expense{color:var(--danger);}

/* ── MONTHLY SUMMARY EXPORT + BUDGET ── */
.month-totals-row{display:flex;gap:10px;margin-top:8px;flex-wrap:wrap;}
.month-total-pill{font-size:12px;padding:4px 10px;border-radius:20px;font-weight:600;}
.month-total-pill.inc{background:#e6f4ea;color:var(--success);}
.month-total-pill.exp{background:#fce8e6;color:var(--danger);}
body.dark .month-total-pill.inc{background:#1a3a24;}
body.dark .month-total-pill.exp{background:#3a1a1a;}

/* ── DEBT NETTING ── */
.net-badge{font-size:11px;padding:2px 8px;border-radius:20px;font-weight:600;margin-left:6px;}
.net-badge.owe{background:#fce8e6;color:var(--danger);}
.net-badge.owed{background:#e6f4ea;color:var(--success);}

.bottom-nav{
  display:none;position:fixed;bottom:0;left:0;right:0;
  height:var(--bottom-nav-h);background:white;
  border-top:1px solid var(--border);z-index:300;
}
.bottom-nav ul{list-style:none;display:flex;height:100%;}
.bottom-nav ul li{flex:1;}
.bn-item{
  display:flex;flex-direction:column;align-items:center;
  justify-content:center;height:100%;width:100%;
  color:var(--muted);font-size:10px;font-weight:600;
  gap:3px;cursor:pointer;border:none;background:none;
  transition:color 0.15s;
}
.bn-item .bn-icon{font-size:20px;}
.bn-item.active{color:var(--primary);}

@media(max-width:768px){
  .sidebar{transform:translateX(-100%);}
  .sidebar.open{transform:translateX(0);box-shadow:4px 0 15px rgba(0,0,0,0.15);}
  .hamburger{display:block;}
  .main{margin-left:0;padding:14px;padding-bottom:calc(var(--bottom-nav-h) + 14px);}
  .bottom-nav{display:block;}
  .form-grid{grid-template-columns:1fr;}
  .summary-grid{grid-template-columns:1fr 1fr;}
  .tile .val{font-size:18px;}
  .nwval{font-size:20px;}
  .tx-item{flex-wrap:wrap;}
  .tx-actions{flex-direction:column;}
  .card{padding:14px 16px;}
  .header h1{font-size:16px;}
}
</style>
</head>
<body>

<div class="header">
  <button class="hamburger" id="hamburgerBtn">☰</button>
  <h1>💰 Finance Tracker</h1>
  <button class="dark-toggle" id="darkToggle" title="Toggle dark mode">🌙</button>
  <button class="btn btn-danger btn-sm" id="clearBtn">🗑 Clear All</button>
</div>

<div class="overlay" id="overlay"></div>

<nav class="sidebar" id="sidebar">
  <div class="nav-section-label">Overview</div>
  <div class="nav-item active" data-page="dashboard"><span class="nav-icon">📊</span> Dashboard</div>
  <hr class="nav-divider">
  <div class="nav-section-label">Transactions</div>
  <div class="nav-item" data-page="add"><span class="nav-icon">➕</span> Add Transaction</div>
  <div class="nav-item" data-page="history"><span class="nav-icon">📋</span> History</div>
  <hr class="nav-divider">
  <div class="nav-section-label">People</div>
  <div class="nav-item" data-page="people"><span class="nav-icon">👥</span> Person-wise</div>
  <hr class="nav-divider">
  <div class="nav-section-label">Reports</div>
  <div class="nav-item" data-page="monthly"><span class="nav-icon">📅</span> Monthly Summary</div>
  <hr class="nav-divider">
  <div class="nav-section-label">Tools</div>
  <div class="nav-item" data-page="recurring"><span class="nav-icon">🔁</span> Recurring</div>
  <div class="nav-item" data-page="budget"><span class="nav-icon">🎯</span> Budgets</div>
