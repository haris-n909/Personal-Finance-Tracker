  /* ─── XLSX ─── */
  function downloadXLSX() {
    if (transactions.length === 0) { alert("No transactions to download."); return; }
    const from   = elFromDate.value;
    const to     = elToDate.value;
    // Warn if filter is active so user doesn't accidentally export partial data
    if ((from || to) && !confirm(`Filter active (${from||"start"} → ${to||"end"}). Export only filtered transactions?

Click Cancel then clear filters to export all.`)) return;
    const sorted = getSortedFiltered(from, to, "", "");
    if (sorted.length === 0) { alert("No transactions in selected date range."); return; }

    const txRows = sorted.map(t => ({
      "Date"       : t.date,
      "Day"        : t.day  || "",
      "Type"       : t.type.charAt(0).toUpperCase() + t.type.slice(1),
      "Category"   : t.category,
      "Amount"     : t.amount,
      "Person"     : PERSON_CATS.includes(t.category) ? (t.person || "") : "",
      "Month"      : t.month || "",
      "Description": t.desc || ""
    }));

    const nw = balance + investments + othersOwe - youOwe;
    const summaryRows = [
      { "Field": "Cash Balance",   "Amount": balance },
      { "Field": "You Owe",        "Amount": youOwe },
      { "Field": "Others Owe You", "Amount": othersOwe },
      { "Field": "Investments",    "Amount": investments },
      { "Field": "Gifts Given",    "Amount": totalGift },
      { "Field": "",               "Amount": "" },
      { "Field": "Net Worth (excl. investments)", "Amount": nw }
    ];

    const personRows = [];
    for (const p in borrowedMap) if (borrowedMap[p] > 0) personRows.push({ "Category": "Borrowed From", "Person": p, "Amount": borrowedMap[p] });
    for (const p in lentMap)     if (lentMap[p]     > 0) personRows.push({ "Category": "Lent To",        "Person": p, "Amount": lentMap[p] });
    for (const p in giftMap)     if (giftMap[p]     > 0) personRows.push({ "Category": "Gift Given To",  "Person": p, "Amount": giftMap[p] });

    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(txRows),      "Transactions");
    XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(summaryRows), "Summary");
    if (personRows.length > 0)
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(personRows), "Person-wise");

    const fn = "Finance_" + (from && to ? `${from}_to_${to}` : from ? `from_${from}` : to ? `till_${to}` : "All") + ".xlsx";
    XLSX.writeFile(wb, fn);
  }

  function importXLSX(event) {
    const file = event.target.files[0];
    if (!file) return;
    if (!file.name.toLowerCase().endsWith(".xlsx")) {
      alert("Please select a valid .xlsx file."); return;
    }
    const reader = new FileReader();
    reader.onload = function (e) {
      try {
        const wb    = XLSX.read(e.target.result, { type: "binary" });
        const sheet = wb.Sheets["Transactions"];
        if (!sheet) { alert("Invalid file. Please use a file exported from this app."); return; }
        const rows = XLSX.utils.sheet_to_json(sheet);
        if (rows.length === 0) { alert("No transactions found in file."); return; }
        if (!confirm(`Import ${rows.length} transactions? This will replace all current data.`)) return;

        balance = youOwe = othersOwe = investments = totalGift = 0;
        transactions = []; borrowedMap = {}; lentMap = {}; giftMap = {};

        // Parse all valid rows first
        const parsed = [];
        rows.forEach(r => {
          const t = {
            date    : String(r["Date"]        || "").trim(),
            day     : String(r["Day"]         || "").trim(),
            amount  : parseFloat(r["Amount"]) || 0,
            type    : String(r["Type"]        || "").toLowerCase().trim(),
            category: String(r["Category"]    || "").trim(),
            person  : String(r["Person"]      || "").trim(),
            month   : String(r["Month"]       || "").trim(),
            desc    : String(r["Description"] || "").trim()
          };
          const allCats = [...INCOME_CATS, ...EXPENSE_CATS];
          const validDate = /^\d{4}-\d{2}-\d{2}$/.test(t.date);
          const validType = t.type === "income" || t.type === "expense";
          const validAmt  = t.amount > 0 && isFinite(t.amount);
          const validCat  = allCats.includes(t.category);
          if (validDate && validAmt && validType && validCat) {
            parsed.push(t);
          }
        });

        // Sort ascending by date so lent always comes before its repayment
        parsed.sort((a, b) => a.date < b.date ? -1 : a.date > b.date ? 1 : 0);

        // Apply in chronological order
        let imported = 0;
        parsed.forEach(t => {
          transactions.push(t);
          apply(t);
          imported++;
        });

        // Re-apply initial data on top of imported transactions
        const initD = loadInitialData();
        if (initD) applyInitialData(initD);
        saveData(); updateAll();
        alert(`✅ Imported ${imported} transactions successfully!`);
      } catch (err) {
        console.error("Import error:", err);
        alert("❌ Import failed. Please use a valid exported file.");
      }
    };
    reader.onerror = function () { alert("❌ Failed to read file."); };
    reader.readAsBinaryString(file);
    event.target.value = "";
  }

